# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Google Sheets (only needed for migration script)
GOOGLE_SHEET_ID=
MARKET_DATA_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Email Center (Resend) — set these in Vercel project settings, NOT in code.
# ---------------------------------------------------------------------------
# Resend API key — required. Get one from resend.com/api-keys.
RESEND_API_KEY=
# Sender address. Default is Resend's onboarding tester (only delivers to your
# Resend account owner's email). Swap for your verified domain sender once
# DNS is set up (e.g. orders@sucrocanada.com).
EMAIL_FROM_ADDRESS=onboarding@resend.dev
# Optional shared secret. When set, the /api/send-email endpoint requires
# Authorization: Bearer <this value>. Generate a long random string. The
# client-side env var below must match.
EMAIL_SHARED_SECRET=
# Client-visible counterpart of EMAIL_SHARED_SECRET. Vite only exposes vars
# prefixed with VITE_. Must equal EMAIL_SHARED_SECRET above.
VITE_EMAIL_SHARED_SECRET=
