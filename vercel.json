{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/data", "destination": "/api/data" },
    { "source": "/api/sync", "destination": "/api/sync" },
    { "source": "/api/market-data", "destination": "/api/market-data" },
    { "source": "/api/extract-po", "destination": "/api/extract-po" },
    { "source": "/api/scan-po-inbox", "destination": "/api/scan-po-inbox" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    { "path": "/api/scan-po-inbox", "schedule": "0 * * * *" }
  ]
}
